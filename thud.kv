#:kivy 2.0.0
#:import Label kivy.uix.label.Label
#:import Image kivy.uix.image.Image
#:import Button kivy.uix.button.Button

<ThudGame>:
    board: main_board

    BoxLayout:
        orientation: 'horizontal'
        spacing: 15
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.7,1
            spacing: 10
            padding: 15,0,0,15
            Label:
                canvas:
                    Color:
                        rgba: 1,1,1,0.8
                size_hint: 1,0.1
                text: "/////"
            Board:
                id: main_board
                pos: self.parent.center

        Button:
            size_hint: 0.3,1
            text: "////"

<Board>:
    cols: 15
    rows: 15
    row_default_height: 30
    col_default_width: 30
    spacing: 2

<Pawn>:
    text: ' / '
    color: 1,1,1,0.8
